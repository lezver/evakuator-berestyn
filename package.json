{
	"name": "evakuator-berestyn",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"build": "npx @tailwindcss/cli -i ./css/input.css -o ./css/style.css --minify",
		"watch": "npx @tailwindcss/cli -i ./css/input.css -o ./css/style.css --watch",
		"start": "npx live-server --port=3000 --open=/index.html",
		"dev": "npm-run-all --parallel watch start"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.2.2",
		"live-server": "^1.2.2",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.3",
		"tailwindcss": "^4.2.2"
	}
}
